  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: You defeated the terror of the abyss and conquered the depths. After handing
    in the creature's lifeless corpse, you were rewarded with a hefty amount of money
    for the invaluable piece of data you retrieved, more than what you even needed
    to pay off your debt. With that, you're finally free from your financial crisis
    and you now know what lies in the darkest pits of the ocean, you've witnessed
    and even fought it yourself. But as a result, that memory will forever haunt
    you and you will never see the ocean the same way ever again.
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f221dcc725f46e9408639bd9aa87fc4a, type: 2}
